<div id="game-wrapper">
  <div id="ui-layer">
    <div id="start-screen">
      <h1 class="pixel-text">SLIPPERY SLIDE</h1>
      <p class="pixel-text">Avoid the mess!</p>
      <div class="menu">
        <button onclick="startGame(4)">EASY</button>
        <button onclick="startGame(7)">MEDIUM</button>
        <button onclick="startGame(11)">HARD</button>
      </div>
    </div>
    <div id="game-over" style="display:none;">
      <h1 class="pixel-text">WIPEOUT!</h1>
      <button onclick="resetGame()">RETRY</button>
    </div>
    <div id="score" class="pixel-text" style="display:none;">0m</div>
  </div>
  <canvas id="gameCanvas"></canvas>
</div>
