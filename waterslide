<div id="game-container">
    <div id="ui">
        <div id="score">SCORE: 0</div>
        <div id="difficulty-select">
            <button onclick="setDifficulty('easy')">EASY</button>
            <button onclick="setDifficulty('medium')">MEDIUM</button>
            <button onclick="setDifficulty('hard')">HARD</button>
        </div>
    </div>
    <div id="slide-wrapper">
        <div id="slide">
            <div id="player"></div>
        </div>
    </div>
    <div id="game-over">
        <div class="game-over-content">
            <h1>GAME OVER!</h1>
            <p>You hit an obstacle!</p>
            <button onclick="resetGame()">RETRY</button>
        </div>
    </div>
</div>

@font-face {
    font-family: 'Pixelify Sans';
    src: url('https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400..700&display=swap') format('woff2');
    /* Fallback if @import doesn't load it */
}

body {
    margin: 0;
    overflow: hidden;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(to bottom, #a2e1f2, #e0f7fa); /* Pastel sky to light blue */
    font-family: 'Pixelify Sans', monospace; /* Pixelated font */
    color: #333;
    text-shadow: 2px 2px #fff;
}

#game-container {
    position: relative;
    width: 320px; /* Pixel perfect width */
    height: 568px; /* Pixel perfect height (e.g., old phone screen) */
    background: linear-gradient(to top, #6dd5ed, #2193b0); /* Deeper water blue */
    border: 8px solid #8fe7f5; /* Lighter water border */
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
}

#ui {
    position: absolute;
    top: 10px;
    width: 100%;
    text-align: center;
    z-index: 100;
    font-size: 24px;
    font-weight: bold;
}

#difficulty-select {
    margin-top: 10px;
}

#difficulty-select button {
    font-family: 'Pixelify Sans', monospace;
    font-size: 16px;
    padding: 8px 15px;
    margin: 0 5px;
    background-color: #ff99c8; /* Pastel pink */
    color: #fff;
    border: 3px solid #f06292; /* Darker pink border */
    border-radius: 8px;
    cursor: pointer;
    box-shadow: 2px 2px #f06292;
    transition: all 0.1s ease-in-out;
}

#difficulty-select button:hover {
    background-color: #f06292;
    box-shadow: 1px 1px #f06292;
    transform: translate(1px, 1px);
}

#slide-wrapper {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 100%;
    perspective: 200px; /* Create 3D effect for the slide */
    overflow: hidden; /* Hide parts of slide that go off screen */
}

#slide {
    position: absolute;
    bottom: 0;
    left: -50%; /* Make it wider than its wrapper for perspective */
    width: 200%; /* Double width */
    height: 150%; /* Extend upwards to create depth */
    background: linear-gradient(90deg, #bbdefb 0%, #e3f2fd 20%, #e3f2fd 80%, #bbdefb 100%); /* Pastel blue slide with lighter middle */
    transform: rotateX(60deg) translateX(25%); /* Rotate and adjust for perspective */
    transform-origin: bottom center;
    box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.2); /* Inner shadow for depth */
}


#player {
    position: absolute;
    bottom: 80px; /* Position him on the slide */
    left: 50%; /* Start in the middle */
    transform: translateX(-50%); /* Center based on its own width */
    width: 40px; /* Player width */
    height: 40px; /* Player height */
    background-color: transparent; /* Transparent base */
    z-index: 10;
    transition: left 0.05s linear; /* Smooth horizontal movement */

    /* Fat Man Pixel Art (Example using box-shadow) */
    box-shadow:
        /* Head */
        0px 0px 0 4px #ffcc99, /* Skin tone */
        0px -4px 0 4px #ffcc99,
        0px 4px 0 4px #ffcc99,
        4px 0px 0 4px #ffcc99,
        -4px 0px 0 4px #ffcc99,

        /* Body */
        0px 12px 0 8px #ffd700, /* Yellow swim shorts */
        0px 20px 0 8px #ffd700,
        -4px 12px 0 8px #ffd700,
        4px 12px 0 8px #ffd700,
        -8px 16px 0 8px #ffd700,
        8px 16px 0 8px #ffd700,

        /* Arms */
        -16px 8px 0 4px #ffcc99,
        16px 8px 0 4px #ffcc99,

        /* Legs (simplified, merging with shorts) */
        -4px 28px 0 4px #ffcc99,
        4px 28px 0 4px #ffcc99;
}

.obstacle {
    position: absolute;
    width: 40px; /* Base width */
    height: 40px; /* Base height */
    background-color: transparent; /* Transparent base */
    z-index: 5;
    transform-origin: center bottom; /* For scaling perspective */
    opacity: 0; /* Start hidden */
    transition: opacity 0.1s ease-out; /* Fade in */
}

/* Obstacle Specific Pixel Art */

/* Poo Pile */
.obstacle.poo {
    box-shadow:
        0 0 0 8px #8b4513, /* Main body */
        -4px -4px 0 4px #a0522d,
        4px -4px 0 4px #a0522d,
        -8px 4px 0 6px #8b4513,
        8px 4px 0 6px #8b4513,
        0 8px 0 10px #8b4513,
        -4px 12px 0 6px #a0522d,
        4px 12px 0 6px #a0522d;
}

/* Ice Cream */
.obstacle.ice-cream {
    box-shadow:
        /* Cone */
        0 0 0 4px #d2b48c,
        -4px 4px 0 4px #d2b48c,
        4px 4px 0 4px #d2b48c,
        -8px 8px 0 4px #d2b48c,
        8px 8px 0 4px #d2b48c,
        0 8px 0 4px #d2b48c,

        /* Scoop */
        0 -4px 0 8px #ffc0cb, /* Pink */
        -4px -8px 0 4px #ffc0cb,
        4px -8px 0 4px #ffc0cb,
        0 -12px 0 6px #ffc0cb;
}

/* Puddle */
.obstacle.puddle {
    box-shadow:
        0 0 0 10px rgba(255, 255, 0, 0.4), /* Main puddle body */
        -8px 0 0 6px rgba(255, 255, 0, 0.3),
        8px 0 0 6px rgba(255, 255, 0, 0.3),
        0 8px 0 8px rgba(255, 255, 0, 0.4),
        -4px 12px 0 4px rgba(255, 255, 0, 0.3),
        4px 12px 0 4px rgba(255, 255, 0, 0.3);
}


#game-over {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 200;
    display: none; /* Hidden by default */
}

.game-over-content {
    background-color: #fff;
    border: 5px solid #ff69b4; /* Hot pink border */
    border-radius: 10px;
    padding: 30px;
    text-align: center;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
}

.game-over-content h1 {
    color: #ff69b4;
    font-size: 48px;
    margin-bottom: 20px;
}

.game-over-content p {
    font-size: 20px;
    margin-bottom: 30px;
}

.game-over-content button {
    font-family: 'Pixelify Sans', monospace;
    font-size: 24px;
    padding: 10px 30px;
    background-color: #81ecec; /* Aqua blue */
    color: #004d40; /* Darker blue-green */
    border: 3px solid #00838f;
    border-radius: 8px;
    cursor: pointer;
    box-shadow: 2px 2px #00838f;
    transition: all 0.1s ease-in-out;
}

.game-over-content button:hover {
    background-color: #00838f;
    color: #fff;
    box-shadow: 1px 1px #00838f;
    transform: translate(1px, 1px);
}

const player = document.getElementById('player');
const slide = document.getElementById('slide');
const scoreElement = document.getElementById('score');
const gameOverScreen = document.getElementById('game-over');

let playerX = 140; // Player's horizontal position (centered on slide)
let score = 0;
let gameActive = false; // Game starts inactive until difficulty is chosen
let keys = {}; // To track pressed keys
let obstacleSpeed = 2; // Base speed, will change with difficulty
let obstacleSpawnRate = 1500; // Base spawn rate (ms), will change with difficulty

const slideWidth = 320; // Matches game-container width
const playerWidth = 40; // Player pixel width
const obstacleWidth = 40; // Obstacle pixel width
const playerMovementSpeed = 4; // Pixels per frame for player

// Difficulty settings
const difficulties = {
    easy: { speed: 2, spawnRate: 1800, scoreMultiplier: 1 },
    medium: { speed: 4, spawnRate: 1200, scoreMultiplier: 2 },
    hard: { speed: 6, spawnRate: 800, scoreMultiplier: 3 }
};

// Map obstacle types to CSS classes
const obstacleTypes = [
    { type: 'poo', className: 'poo' },
    { type: 'ice-cream', className: 'ice-cream' },
    { type: 'puddle', className: 'puddle' }
];

// Event listeners for player movement
document.addEventListener('keydown', (e) => {
    if (gameActive) {
        keys[e.key] = true;
    }
});
document.addEventListener('keyup', (e) => {
    if (gameActive) {
        keys[e.key] = false;
    }
});

// Main game loop for player movement
function updatePlayerPosition() {
    if (!gameActive) return;

    if (keys['ArrowLeft']) {
        playerX -= playerMovementSpeed;
    }
    if (keys['ArrowRight']) {
        playerX += playerMovementSpeed;
    }

    // Clamp player position to within the slide boundaries
    // The slide is 320px wide, player is 40px. Player's left edge can go from 0 to 280 (320-40)
    playerX = Math.max(0, Math.min(playerX, slideWidth - playerWidth));

    player.style.left = playerX + 'px';
    requestAnimationFrame(updatePlayerPosition);
}

// Function to set game difficulty
function setDifficulty(level) {
    if (gameActive) return; // Prevent changing difficulty mid-game
    
    obstacleSpeed = difficulties[level].speed;
    obstacleSpawnRate = difficulties[level].spawnRate;
    scoreMultiplier = difficulties[level].scoreMultiplier; // Added score multiplier
    
    // Hide difficulty buttons and start game
    document.getElementById('difficulty-select').style.display = 'none';
    startGame();
}

function startGame() {
    gameActive = true;
    score = 0;
    scoreElement.innerText = `SCORE: 0`;
    gameOverScreen.style.display = 'none';

    // Remove any existing obstacles from a previous game
    document.querySelectorAll('.obstacle').forEach(o => o.remove());

    // Start game loops
    requestAnimationFrame(updatePlayerPosition);
    spawnObstacleLoop();
}

function spawnObstacleLoop() {
    if (!gameActive) return;

    spawnObstacle();
    setTimeout(spawnObstacleLoop, obstacleSpawnRate);
}

function spawnObstacle() {
    const obstacle = document.createElement('div');
    const randomObstacleType = obstacleTypes[Math.floor(Math.random() * obstacleTypes.length)];
    
    obstacle.className = `obstacle ${randomObstacleType.className}`;
    
    // Position obstacle randomly across the visible slide width
    const obsX = Math.random() * (slideWidth - obstacleWidth);
    obstacle.style.left = obsX + 'px';
    obstacle.style.top = '0px'; // Start at the top of the visible area
    
    slide.appendChild(obstacle); // Append to the slide for relative positioning

    let currentObsTop = 0; // Current vertical position of the obstacle
    
    const moveInterval = setInterval(() => {
        if (!gameActive) {
            clearInterval(moveInterval);
            obstacle.remove();
            return;
        }

        currentObsTop += obstacleSpeed;
        obstacle.style.top = currentObsTop + 'px';

        // Collision Detection:
        // Check if obstacle's bottom has reached player's top
        // And if their horizontal positions overlap
        if (currentObsTop + obstacleWidth > 450 && currentObsTop < 500) { // Player is around 480-520px from top
            // Calculate horizontal overlap
            if (playerX < obsX + obstacleWidth && playerX + playerWidth > obsX) {
                endGame();
                clearInterval(moveInterval);
                return;
            }
        }

        // Remove obstacle if it goes off screen (past player)
        if (currentObsTop > 600) { // Off the bottom of the visible screen
            clearInterval(moveInterval);
            obstacle.remove();
            score += (10 * scoreMultiplier); // Increase score
            scoreElement.innerText = `SCORE: ${score}`;
        }

        // Apply perspective scaling to obstacles
        // This makes them look like they're coming from far away
        const scaleFactor = 0.5 + (currentObsTop / 600) * 0.5; // Scales from 0.5x to 1x
        obstacle.style.transform = `scale(${scaleFactor})`;
        obstacle.style.opacity = scaleFactor; // Fade in as they get closer

    }, 20); // Update every 20ms for smooth animation
}


function endGame() {
    gameActive = false;
    gameOverScreen.style.display = 'flex';
    // Optionally stop all obstacle intervals, but reload is simpler for CodePen
    // clearIntervals(all_obstacle_intervals); // Not implemented as separate array here
}

function resetGame() {
    // A simple page reload is the easiest way to reset all intervals and states for a CodePen
    location.reload(); 
}

// Initial call to start the player update loop (it will pause itself if gameActive is false)
requestAnimationFrame(updatePlayerPosition);
